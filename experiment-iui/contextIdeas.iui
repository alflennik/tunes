getProfilePage = () => {  
  return createHtmlTemplate([
    .h1("Profile")
    .div("Username: {.:user.username}")
  ])
}

getHomePage = () => {
  .:user<!> = recoverSession()
  if !.:user<!>, return getSignInPage()

  return getProfilePage()
}

test('profile page renders', () => {
  .:user = createMockUser()
  getProfilePage()
})

getProfilePage() 
